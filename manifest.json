{
  "manifest_version": 3,
  "name": "Gemini Chat Saver",
  "version": "1.0",
  "description": "Lấy nội dung chat từ Gemini mà không cần đăng nhập lại.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png", 
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content.js"]
    }
  ]
}